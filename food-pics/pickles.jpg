logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.spendwithpennies.com\/#\/schema\/logo\/image\/","url":"https:\/\/www.spendwithpennies.com\/wp-content\/uploads\/2021\/08\/cropped-favicon.jpg","contentUrl":"https:\/\/www.spendwithpennies.com\/wp-content\/uploads\/2021\/08\/cropped-favicon.jpg","width":512,"height":512,"caption":"Spend With Pennies"},"image":{"@id":"https:\/\/www.spendwithpennies.com\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/ispendwithpennies","https:\/\/x.com\/spendpennies"]},{"@type":"Person","@id":"https:\/\/www.spendwithpennies.com\/#\/schema\/person\/1212dd6ee15c360b58032f7b23d46110","name":"Holly Nilsson","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/4996e7e08612c9ba4308e0cf9b40568daafbe42e98cda742f8b5301caa5a1847?s=96&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/4996e7e08612c9ba4308e0cf9b40568daafbe42e98cda742f8b5301caa5a1847?s=96&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/4996e7e08612c9ba4308e0cf9b40568daafbe42e98cda742f8b5301caa5a1847?s=96&r=g","caption":"Holly Nilsson"},"description":"Holly Nilsson is the creator of Spend With Pennies, where she creates easy, comforting recipes made for real life. She is also the author of “Everyday Comfort,” which promises to inspire even more hearty, home-cooked meals.","sameAs":["https:\/\/www.spendwithpennies.com\/author\/holly\/","https:\/\/www.facebook.com\/ispendwithpennies\/","https:\/\/www.instagram.com\/spendpennies\/","https:\/\/www.pinterest.com\/spendpennies\/","https:\/\/x.com\/spendpennies","https:\/\/www.youtube.com\/channel\/UC-vRqs21vJfUNcu8D8xsfSA"],"award":["Globe & Mail Best-Selling Cookbook","Amazon best-seller","Indigo best-seller"],"knowsAbout":["cookbook author","food blogging","meal planning","photography","speaking","email marketing","golf"],"jobTitle":"Food Blogger, Founder, Chef, Recipe Developer, Cookbook Author","worksFor":"Spend With Pennies","url":"https:\/\/www.spendwithpennies.com\/author\/holly\/"},{"@type":"Recipe","name":"Fried Pickles","author":{"@id":"https:\/\/www.spendwithpennies.com\/#\/schema\/person\/1212dd6ee15c360b58032f7b23d46110"},"description":"Fried pickles are crispy, tangy, and so addictive. They’re a fun snack that’s perfect for dipping and sharing!","datePublished":"2026-01-21T08:14:00+00:00","image":["https:\/\/www.spendwithpennies.com\/wp-content\/uploads\/2025\/10\/Cropped-Crispy-Fried-Pickles-SpendWithPennies.jpg","https:\/\/www.spendwithpennies.com\/wp-content\/uploads\/2025\/10\/Cropped-Crispy-Fried-Pickles-SpendWithPennies-500x500.jpg","https:\/\/www.spendwithpennies.com\/wp-content\/uploads\/2025\/10\/Cropped-Crispy-Fried-Pickles-SpendWithPennies-500x375.jpg","https:\/\/www.spendwithpennies.com\/wp-content\/uploads\/2025\/10\/Cropped-Crispy-Fried-Pickles-SpendWithPennies-480x270.jpg"],"recipeYield":["4","4 servings"],"prepTime":"PT15M","cookTime":"PT10M","totalTime":"PT25M","recipeIngredient":["12  dill pickle slices","1½ cups Panko bread crumbs","½  teaspoon cayenne pepper (optional)","½ teaspoon  salt","oil (for frying )","1 cup all-purpose flour","1 cup milk","1 teaspoon baking powder","1  egg","1 teaspoon paprika","½ teaspoon black pepper","½ teaspoon dried dill (optional)"],"recipeInstructions":[{"@type":"HowToStep","text":"In a non-stick skillet, preheat oil to 360°F to 370°F. In a medium mixing bowl, whisk Panko, cayenne pepper, and salt.","name":"In a non-stick skillet, preheat oil to 360°F to 370°F. In a medium mixing bowl, whisk Panko, cayenne pepper, and salt.","url":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#wprm-recipe-134594-step-0-0"},{"@type":"HowToStep","text":"In another medium mixing bowl, whisk flour, milk, baking powder, egg, paprika, black pepper, and dill until smooth. Let rest for at least 5 minutes.","name":"In another medium mixing bowl, whisk flour, milk, baking powder, egg, paprika, black pepper, and dill until smooth. Let rest for at least 5 minutes.","url":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#wprm-recipe-134594-step-0-1"},{"@type":"HowToStep","text":"Meanwhile, dab the pickle slices dry with paper towels.","name":"Meanwhile, dab the pickle slices dry with paper towels.","url":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#wprm-recipe-134594-step-0-2"},{"@type":"HowToStep","text":"Place about ½ cup of Panko bread crumb mixture in a small bowl.*","name":"Place about ½ cup of Panko bread crumb mixture in a small bowl.*","url":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#wprm-recipe-134594-step-0-3"},{"@type":"HowToStep","text":"Dip each pickle slice in the flour mixture and then gently dip into the bread crumbs. Set the dipped pickles on a baking sheet and let them rest for a few minutes while you dip the remaining pickles. This will allow the crumbs to stick better.","name":"Dip each pickle slice in the flour mixture and then gently dip into the bread crumbs. Set the dipped pickles on a baking sheet and let them rest for a few minutes while you dip the remaining pickles. This will allow the crumbs to stick better.","url":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#wprm-recipe-134594-step-0-4"},{"@type":"HowToStep","text":"Fry in small batches for 3 to 4 minutes or until brown and crispy. Transfer to a paper towel lined plate and immediately sprinkle with salt.","name":"Fry in small batches for 3 to 4 minutes or until brown and crispy. Transfer to a paper towel lined plate and immediately sprinkle with salt.","url":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#wprm-recipe-134594-step-0-5"},{"@type":"HowToStep","text":"Serve with ranch or your favorite dipping sauce.","name":"Serve with ranch or your favorite dipping sauce.","url":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#wprm-recipe-134594-step-0-6"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.95","ratingCount":"191","reviewCount":"9"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"These were so good! The only thing I didn't do was to sprinkle them with salt, and I was glad I didn't. I used Claussen pickles and I find them already salty enough. I had a ton of batter left over, so next time I'll 1\/2 that part of the recipe. Thanks for another keeper recipe!","author":{"@type":"Person","name":"Kelly"},"datePublished":"2025-10-20"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Nicely Done! Ty for sharing, I will keep this bookmark for when the next time i am Thirsty for more!","author":{"@type":"Person","name":"Chaz"},"datePublished":"2024-12-23"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"A family favorite  .","author":{"@type":"Person","name":"Di"},"datePublished":"2024-08-04"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Great batter!  Will make them again!","author":{"@type":"Person","name":"Shawna"},"datePublished":"2024-07-10"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I Love this recipe! I was craving full fried pickles and made these, very satisfying! My family asked me to make more for our reunion! Thank you!!!","author":{"@type":"Person","name":"Viviana M."},"datePublished":"2024-06-27"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I really enjoy your emails.One of the things that makes yours different is that you have a spot to jump to recipe.I save them  to Pinterest. My question is, is it possible for you to put in the recipe a d\/l tab that I can share to my phone\/recipe app.Thank you,Jaye","author":{"@type":"Person","name":"Jaye"},"datePublished":"2023-11-05"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"These came out perfect. my pickles were a little thick so I'll cut them in half next time. but these are as good or better than any restaurant pickles I've had.","author":{"@type":"Person","name":"Scott"},"datePublished":"2023-07-08"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"super crunchy and the coating stayed in tact with each bite! Friend gave me his shoe to batter\/coat\/fry he lived it sooooo much!","author":{"@type":"Person","name":"Mary W."},"datePublished":"2023-04-08"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"The waffle house has found its new host","author":{"@type":"Person","name":"Zenith686"},"datePublished":"2023-02-15"}],"recipeCategory":["Appetizer","Party Food","Side Dish","Snack"],"recipeCuisine":["American"],"keywords":"fried dill pickles, fried pickle recipe, fried pickles, fried pickles recipe","nutrition":{"@type":"NutritionInformation","calories":"250 kcal","carbohydrateContent":"45 g","proteinContent":"10 g","fatContent":"3 g","saturatedFatContent":"1 g","transFatContent":"0.01 g","cholesterolContent":"44 mg","sodiumContent":"666 mg","fiberContent":"2 g","sugarContent":"5 g","unsaturatedFatContent":"2 g","servingSize":"1 serving"},"@id":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#recipe","isPartOf":{"@id":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/#article"},"mainEntityOfPage":"https:\/\/www.spendwithpennies.com\/crispy-fried-dill-pickles\/"}]}</script>
